# GitHub repository base URL — used for "Report a change" links on the About page and elsewhere.
# Change this to your fork URL if you deploy your own instance.
# Example: https://github.com/yourusername/gdpr-ai-directory
NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/yourusername/gdpr-ai-directory

# Required: Neon Postgres connection string
# Get from: https://console.neon.tech → your project → Connection Details → Connection string
# Use the "pooled" connection string (includes ?sslmode=require)
DATABASE_URL=

# Required in production: Vercel Cron job secret
# Vercel sets this automatically when a cron is defined in vercel.json.
# For local testing, set any string and pass it as: Authorization: Bearer <value>
CRON_SECRET=

# Optional: API keys for live provider model syncing
# Without these, the corresponding adapter will be skipped during sync.

# Mistral — https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Scaleway Generative APIs — https://console.scaleway.com/iam/api-keys
SCW_SECRET_KEY=

# Stackit Model Serving — https://portal.stackit.cloud/
STACKIT_API_KEY=

# Amazon Bedrock — used by the Bedrock adapter to fetch all hosted models (Claude, Mistral, Llama, etc.)
# IAM user needs: bedrock:ListFoundationModels permission
# Get from: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Region to query — use an EU region for accurate EU model availability
# Options: eu-west-1 (Ireland), eu-west-2 (London), eu-west-3 (Paris), eu-central-1 (Frankfurt), eu-north-1 (Stockholm)
AWS_REGION=eu-west-1

# OpenAI — used by research-providers.ts and translate-providers.ts scripts
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
