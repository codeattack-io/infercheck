{
  "name": "gdpr-ai-directory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css,mjs,cjs}\"",
    "import": "bun run scripts/import-models-dev.ts",
    "validate": "bun run scripts/validate-data.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "sync:models": "bun run scripts/sync-models.ts",
    "sync:models:dry": "bun run scripts/sync-models.ts --dry-run"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/nextjs": "^10.47.0",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.3.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.1",
    "dotenv-expand": "^12.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@sentry/cli",
    "sharp",
    "unrs-resolver"
  ]
}
