{
  "name": "infercheck",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css,mjs,cjs}\"",
    "import": "bun run scripts/import-models-dev.ts",
    "validate": "bun run scripts/validate-data.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "sync:models": "bun run scripts/sync-models.ts",
    "sync:models:dry": "bun run scripts/sync-models.ts --dry-run",
    "research:providers": "bun run scripts/research-providers.ts --all",
    "research:provider": "bun run scripts/research-providers.ts --provider",
    "translate:providers": "bun run scripts/translate-providers.ts --all",
    "translate:provider": "bun run scripts/translate-providers.ts --provider"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@aws-sdk/client-bedrock": "^3.1029.0",
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/nextjs": "^10.48.0",
    "ai": "^6.0.158",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.3.0",
    "next": "16.2.2",
    "next-intl": "^4.9.1",
    "p-queue": "^9.1.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bun": "^1.3.12",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.1",
    "dotenv-expand": "^12.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.2",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@sentry/cli",
    "sharp",
    "unrs-resolver"
  ]
}
